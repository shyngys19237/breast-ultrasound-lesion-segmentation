IMAGENET_MEAN = [0.485, 0.456, 0.406]
IMAGENET_STD = [0.229, 0.224, 0.225]

def segmentation_transform(image: Image.Image, mask: Image.Image, train: bool):
    image = ensure_rgb(image)
    mask = ensure_l(mask)

    if train:
        if random.random() < 0.5:
            image = TF.hflip(image)
            mask = TF.hflip(mask)

        if random.random() < 0.5:
            image = TF.vflip(image)
            mask = TF.vflip(mask)

        if random.random() < 0.3:
            angle = random.choice([-10, -5, 5, 10])
            image = TF.rotate(image, angle, interpolation=InterpolationMode.BILINEAR)
            mask = TF.rotate(mask, angle, interpolation=InterpolationMode.NEAREST)

        if random.random() < 0.25:
            image = ImageEnhance.Contrast(image).enhance(random.uniform(0.9, 1.1))
            image = ImageEnhance.Brightness(image).enhance(random.uniform(0.9, 1.1))

    image = image.resize((IMAGE_SIZE, IMAGE_SIZE), resample=Image.BILINEAR)
    mask = mask.resize((IMAGE_SIZE, IMAGE_SIZE), resample=Image.NEAREST)

    image_t = TF.to_tensor(image)
    image_t = TF.normalize(image_t, mean=IMAGENET_MEAN, std=IMAGENET_STD)

    mask_t = torch.from_numpy((np.array(mask) > 0).astype(np.float32)).unsqueeze(0)

    return image_t, mask_t



class BUSISegmentationDataset(Dataset):
    def __init__(self, dataframe: pd.DataFrame, train: bool = True):
        self.df = dataframe.reset_index(drop=True)
        self.train = train

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):
        row = self.df.iloc[idx]

        image = Image.open(row["image_path"])
        mask = Image.open(row["merged_mask_path"])

        image_t, mask_t = segmentation_transform(image, mask, train=self.train)

        return image_t, mask_t, row["sample_id"], row["image_path"], row["merged_mask_path"]


train_ds = BUSISegmentationDataset(train_df, train=True)
val_ds = BUSISegmentationDataset(val_df, train=False)
