def set_seed(seed: int = 42) -> None:
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed_all(seed)

set_seed(SEED)


def ensure_rgb(img: Image.Image) -> Image.Image:
    return img.convert("RGB")

def ensure_l(img: Image.Image) -> Image.Image:
    return img.convert("L")

def safe_stem(text: str) -> str:
    return re.sub(r"[^A-Za-z0-9_]+", "_", text)

def infer_label_from_path(path: Path):
    parts_lower = [p.lower() for p in path.parts]
    for cls in CLASS_NAMES:
        if cls in parts_lower:
            return cls
    return None

def canonical_key(path: Path) -> str:

    return re.sub(r"_mask(?:_\d+)?$", "", path.stem)

def load_binary_mask(mask_path: str) -> np.ndarray:
    mask = ensure_l(Image.open(mask_path))
    arr = (np.array(mask) > 0).astype(np.uint8)
    return arr

def merge_masks(mask_paths, save_path: Path, size_wh):
    w, h = size_wh
    merged = np.zeros((h, w), dtype=np.uint8)

    for mp in mask_paths:
        arr = load_binary_mask(mp)
        if arr.shape != (h, w):
            arr_img = Image.fromarray((arr * 255).astype(np.uint8))
            arr_img = arr_img.resize((w, h), resample=Image.NEAREST)
            arr = (np.array(arr_img) > 0).astype(np.uint8)
        merged = np.maximum(merged, arr)

    Image.fromarray((merged * 255).astype(np.uint8)).save(save_path)
    return save_path, int(merged.sum() > 0)

def overlay_mask(image_np: np.ndarray, mask_np: np.ndarray, alpha: float = 0.35) -> np.ndarray:
    image_np = image_np.astype(np.uint8)
    mask_bin = (mask_np > 0).astype(np.uint8)

    red = np.zeros_like(image_np)
    red[..., 0] = 255

    blended = np.where(
        mask_bin[..., None] == 1,
        (1 - alpha) * image_np + alpha * red,
        image_np,
    )
    return blended.astype(np.uint8)

def dice_loss_from_logits(logits: torch.Tensor, targets: torch.Tensor) -> torch.Tensor:
    probs = torch.sigmoid(logits)
    targets = (targets > 0.5).float()

    dims = (1, 2, 3)
    intersection = (probs * targets).sum(dims)
    denom = probs.sum(dims) + targets.sum(dims)

    dice = (2 * intersection + 1e-7) / (denom + 1e-7)
    return 1 - dice.mean()

def dice_iou_from_logits(logits: torch.Tensor, targets: torch.Tensor, threshold: float = 0.5):
    probs = torch.sigmoid(logits)
    preds = (probs > threshold).float()
    targets = (targets > 0.5).float()

    dims = (1, 2, 3)
    intersection = (preds * targets).sum(dims)
    pred_sum = preds.sum(dims)
    target_sum = targets.sum(dims)
    union = pred_sum + target_sum - intersection

    dice = ((2 * intersection + 1e-7) / (pred_sum + target_sum + 1e-7)).mean()
    iou = ((intersection + 1e-7) / (union + 1e-7)).mean()

    return dice, iou



def build_busi_segmentation_dataframe():
    root = Path("/kaggle/input")

    grouped = defaultdict(lambda: {"image": None, "masks": [], "label_name": None})
    scanned_png = 0

    for p in root.rglob("*.png"):
        scanned_png += 1

        label_name = infer_label_from_path(p)
        if label_name is None:
            continue

        key = f"{label_name}__{canonical_key(p)}"

        if re.search(r"_mask(?:_\d+)?$", p.stem.lower()):
            grouped[key]["masks"].append(str(p))
        else:
            grouped[key]["image"] = str(p)

        grouped[key]["label_name"] = label_name

    rows = []
    for key, item in grouped.items():
        if item["image"] is None:
            continue

        img_path = Path(item["image"])
        label_name = item["label_name"]

        img = ensure_rgb(Image.open(img_path))
        w, h = img.size

        merged_mask_path = MERGED_MASK_DIR / f"{safe_stem(key)}.png"
        _, has_mask = merge_masks(item["masks"], merged_mask_path, (w, h))

        rows.append({
            "image_path": str(img_path),
            "merged_mask_path": str(merged_mask_path),
            "label_name": label_name,
            "label_id": LABEL_TO_ID[label_name],
            "mask_paths": json.dumps(item["masks"]),
            "has_mask": int(has_mask),
            "sample_id": safe_stem(key),
        })

    if len(rows) == 0:
        raise FileNotFoundError(
            "No BUSI images found in /kaggle/input. "
            "Make sure the BUSI dataset is attached."
        )

    df = pd.DataFrame(rows).sort_values(["label_id", "sample_id"]).reset_index(drop=True)

    print(f"Scanned PNG files: {scanned_png}")
    print(f"Built dataset rows: {len(df)}")

    return df


